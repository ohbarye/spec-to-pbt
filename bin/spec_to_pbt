#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "fileutils"
require_relative "../lib/spec_to_pbt"

options = { output_dir: "generated" }

OptionParser.new do |opts|
  opts.banner = "Usage: spec_to_pbt INPUT.als [options]"

  opts.on("-o", "--output DIR", "Output directory (default: generated)") do |v|
    options[:output_dir] = v
  end

  opts.on("--stateful", "Generate a Pbt.stateful scaffold instead of the unified stateless generator") do
    options[:stateful] = true
  end

  opts.on("--with-config", "Generate a companion Ruby config file for stateful SUT wiring") do
    options[:with_config] = true
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end

  opts.on("-v", "--version", "Show version") do
    puts "spec_to_pbt #{SpecToPbt::VERSION}"
    exit
  end
end.parse!

if ARGV.empty?
  warn "Error: No input file specified"
  warn "Usage: spec_to_pbt INPUT.als [options]"
  exit 1
end

input_file = ARGV[0]

unless File.exist?(input_file)
  warn "Error: File not found: #{input_file}"
  exit 1
end

# Parse the Alloy specification
source = File.read(input_file)
parser = SpecToPbt::Parser.new
raw_spec = parser.parse(source)
spec = SpecToPbt::Frontends::Alloy::Adapter.new.adapt(raw_spec)

if options[:with_config] && !options[:stateful]
  warn "Error: --with-config is only supported with --stateful"
  exit 1
end

# Generate PBT code
generator = if options[:stateful]
  SpecToPbt::StatefulGenerator.new(spec)
else
  SpecToPbt::Generator.new(spec)
end
pbt_code = generator.generate

# Create output directory if it doesn't exist
FileUtils.mkdir_p(options[:output_dir])

# Output filename
base = File.basename(input_file, ".als")
output_file = File.join(options[:output_dir], "#{base}_pbt.rb")

# Write the generated code
File.write(output_file, pbt_code)

puts "Generated: #{output_file}"

if options[:stateful] && options[:with_config]
  config_output_file = File.join(options[:output_dir], "#{File.basename(input_file, '.als')}_pbt_config.rb")

  if File.exist?(config_output_file)
    puts "Preserved user-owned config: #{config_output_file}"
  else
    File.write(config_output_file, generator.generate_config)
    puts "Generated: #{config_output_file}"
  end
end

if options[:stateful]
  puts "Next: edit #{File.join(options[:output_dir], "#{base}_pbt_config.rb")} for SUT wiring" if options[:with_config]
  puts "Next: provide #{File.join(options[:output_dir], "#{base}_impl.rb")} for implementation behavior"
  puts "Next: run ALLOY_TO_PBT_RUN_STATEFUL_SCAFFOLD=1 bundle exec rspec #{output_file}"
  puts "Note: stateful scaffolds require pbt >= #{SpecToPbt::PBT_STATEFUL_MIN_VERSION} with Pbt.stateful"
  puts "Note: install or update pbt, then rerun bundle exec rspec if the generated scaffold reports a runtime preflight error"
end
